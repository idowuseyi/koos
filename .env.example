# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
# Runtime (app queries): use the Supabase TRANSACTION pooler — IPv4, works on
# Vercel serverless. Port 6543, user is postgres.<project-ref>.
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Migrations (drizzle-kit) + any session-mode use: DIRECT/session connection.
# Use the Session pooler (port 5432) — also IPv4. Optional locally; falls back
# to DATABASE_URL if unset.
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DIRECT_URL=

# OpenAI
OPENAI_API_KEY=

# Zoho Mail
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_SECURE=true
ZOHO_SMTP_USER=
ZOHO_SMTP_PASS=
ZOHO_MAIL_FROM=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
